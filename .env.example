# ─────────────────────────────────────────────────────────────────
#  .env — for LOCAL development only
#  On Render: set these in Dashboard → Environment Variables
# ─────────────────────────────────────────────────────────────────

# ── AI — FREE ─────────────────────────────────────────────────────
# Get in 30s: aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy...
GEMINI_MODEL=gemini-1.5-flash

# ── Resume — already hosted, no encoding needed ───────────────────
RESUME_URL=https://mayurkoli.mentesa.live/Mayur%20Koli%20Resume%202026%20AI%20Engineer.pdf
RESUME_PATH=/tmp/resume.pdf

# ── Database — free, lives in /tmp ───────────────────────────────
DATABASE_PATH=/tmp/jobs.db

# ── Gmail ─────────────────────────────────────────────────────────
GMAIL_ADDRESS=you@gmail.com
# App Password (not real password): myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Your profile ─────────────────────────────────────────────────
USER_FULL_NAME=Mayur Koli
USER_EMAIL=mayur@gmail.com
USER_PHONE=+91-XXXXXXXXXX
USER_LOCATION=India (Open to Remote)
USER_LINKEDIN=https://linkedin.com/in/mayurkoli
USER_GITHUB=https://github.com/mayurkoli
USER_PORTFOLIO=https://mayurkoli.mentesa.live

# ── Job search ────────────────────────────────────────────────────
JOB_TITLES=["AI Engineer", "ML Engineer", "LLM Engineer", "Python Developer", "Backend Engineer"]
JOB_KEYWORDS=["Python", "LLM", "Machine Learning", "FastAPI", "RAG", "NLP", "TensorFlow", "PyTorch"]
JOB_LOCATION=Remote
DAILY_LIMIT=50
RUN_HOUR=8
RUN_MINUTE=0
TIMEZONE=Asia/Kolkata

# ── Optional free API keys ────────────────────────────────────────
# Hunter.io: 25 free email lookups/month — hunter.io/users/sign_up
HUNTER_API_KEY=
# Adzuna: 250 free req/day — developer.adzuna.com
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# 2captcha: ~$1/month for CAPTCHA solving on form-fill
TWOCAPTCHA_API_KEY=
