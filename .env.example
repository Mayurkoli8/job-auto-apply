# ─────────────────────────────────────────────
#  REQUIRED — AI (FREE) & Email
# ─────────────────────────────────────────────

# Google Gemini API — 100% FREE
# Get key in 30 seconds: aistudio.google.com/app/apikey
# Free limits: gemini-1.5-flash → 1,500 req/day | 1M tokens/min
GEMINI_API_KEY=AIzaSy...
# Model options (all free): gemini-1.5-flash | gemini-1.5-pro | gemini-2.0-flash
GEMINI_MODEL=gemini-1.5-flash

# Gmail — use an App Password, NOT your real password
# Guide: myaccount.google.com/apppasswords
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ─────────────────────────────────────────────
#  YOUR PROFILE
# ─────────────────────────────────────────────
USER_FULL_NAME=Jane Doe
USER_EMAIL=jane@gmail.com
USER_PHONE=+1-555-000-0000
USER_LOCATION=San Francisco, CA (Open to Remote)
USER_LINKEDIN=https://linkedin.com/in/janedoe
USER_GITHUB=https://github.com/janedoe
USER_PORTFOLIO=https://janedoe.dev
RESUME_PATH=uploads/resume.pdf

# ─────────────────────────────────────────────
#  JOB SEARCH PREFERENCES
# ─────────────────────────────────────────────
JOB_TITLES=["Software Engineer", "Backend Developer", "Full Stack Engineer", "Python Developer"]
JOB_KEYWORDS=["Python", "FastAPI", "React", "PostgreSQL", "AWS"]
JOB_LOCATION=Remote
EXPERIENCE_LEVEL=mid-level
MIN_SALARY=80000
EXCLUDED_COMPANIES=["Company A", "Company B"]

# ─────────────────────────────────────────────
#  AUTOMATION SETTINGS
# ─────────────────────────────────────────────
DAILY_LIMIT=50
RUN_HOUR=8
RUN_MINUTE=0
TIMEZONE=America/New_York
MIN_DELAY_SECONDS=3
MAX_DELAY_SECONDS=12

# ─────────────────────────────────────────────
#  OPTIONAL FREE API KEYS
# ─────────────────────────────────────────────
# Hunter.io — 25 free email lookups/month (hunter.io)
HUNTER_API_KEY=

# Adzuna — free job search API (developer.adzuna.com)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# The Muse — free job API (themuse.com/developers)
THE_MUSE_API_KEY=

# ─────────────────────────────────────────────
#  CAPTCHA (optional — only needed for form-fill on captcha-protected sites)
# ─────────────────────────────────────────────
# 2captcha — ~$1 per 1000 solves
TWOCAPTCHA_API_KEY=
